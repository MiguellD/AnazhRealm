        "signaling": "node signaling-server.js",
        "lint": "eslint anazhRealm.js save-server.js signaling-server.js",
        "lint:fix": "eslint --fix anazhRealm.js save-server.js signaling-server.js",
        "format": "prettier --write anazhRealm.js save-server.js signaling-server.js",
        "format:check": "prettier --check anazhRealm.js save-server.js signaling-server.js",
